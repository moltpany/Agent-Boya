{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/moltpany/Agent-Boya/schemas/music-diary.schema.json",
  "title": "Agent-Boya Music Diary Dataset",
  "description": "A source-grounded dataset of musical works organised into playlists (collections) and by geographic origin. Designed for a static site with a Leaflet map (popups jump to a shared detail panel) and clickable collection lists.",
  "type": "object",
  "additionalProperties": true,
  "required": ["collections", "entries"],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "description": { "type": "string" },
        "curatedBy": { "type": "string" },
        "updated": { "type": "string" }
      }
    },
    "collections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "title"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "intro": { "type": "string", "description": "Optional longer playlist-level guide (why these pieces / how to listen), rendered as a callout below the one-line description." },
          "kind": { "type": "string", "enum": ["playlist", "concert"], "description": "Optional. Renders under the playlists section (default) or the concerts section." },
          "order": { "type": "string", "enum": ["asis"], "description": "Optional. 'asis' keeps dataset order (e.g. a concert program) instead of sorting by year." },
          "badge": { "type": "string", "description": "Optional short label shown on the collection card, e.g. '★ heard live'." }
        }
      }
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "id",
          "title",
          "work",
          "composer",
          "year",
          "city",
          "country",
          "lat",
          "lng",
          "collections",
          "blurb",
          "background",
          "meaning",
          "source"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "title": { "type": "string", "minLength": 1 },
          "work": { "type": "string", "minLength": 1 },
          "composer": { "type": "string", "minLength": 1 },
          "year": { "type": "integer" },
          "city": { "type": "string", "minLength": 1 },
          "country": { "type": "string", "minLength": 1 },
          "lat": { "type": "number", "minimum": -90, "maximum": 90 },
          "lng": { "type": "number", "minimum": -180, "maximum": 180 },
          "mood": { "type": "string" },
          "collections": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
            "uniqueItems": true
          },
          "blurb": { "type": "string", "minLength": 1 },
          "background": { "type": "string", "minLength": 1 },
          "meaning": { "type": "string", "minLength": 1 },
          "source": { "$ref": "#/$defs/source" },
          "sources": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/$defs/source" }
          },
          "quote": {
            "type": "object",
            "additionalProperties": true,
            "description": "Optional. A verified composer note / creative insight, with a source.",
            "required": ["text", "source"],
            "properties": {
              "text": { "type": "string", "minLength": 1 },
              "source": { "$ref": "#/$defs/source-lite" }
            }
          },
          "listening": {
            "type": "object",
            "additionalProperties": true,
            "required": ["target"],
            "properties": {
              "target": { "type": "string", "minLength": 1 },
              "query": { "type": "string" }
            }
          },
          "place": {
            "type": "object",
            "additionalProperties": true,
            "required": ["name", "address", "certainty", "note", "source"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "address": { "type": "string", "minLength": 1 },
              "certainty": { "type": "string", "minLength": 1 },
              "note": { "type": "string", "minLength": 1 },
              "source": { "$ref": "#/$defs/source-lite" }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "source-lite": {
      "type": "object",
      "additionalProperties": true,
      "required": ["label", "url"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri" }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": true,
      "required": ["label", "url", "summary"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri" },
        "summary": { "type": "string", "minLength": 1 }
      }
    }
  }
}
