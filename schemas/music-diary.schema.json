{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/moltpany/Agent-Boya/schemas/music-diary.schema.json",
  "title": "Agent-Boya Music Diary Dataset",
  "description": "A source-grounded dataset of musical works organised by emotional theme and geographic origin. Designed for a dual-view (map + theme) static site.",
  "type": "object",
  "additionalProperties": true,
  "required": ["themes", "entries"],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "description": { "type": "string" },
        "curatedBy": { "type": "string" },
        "updated": { "type": "string" }
      }
    },
    "themes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "name": { "type": "string", "minLength": 1 },
          "tagline": { "type": "string" },
          "blurb": { "type": "string" }
        }
      }
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "id",
          "title",
          "work",
          "composer",
          "year",
          "city",
          "country",
          "lat",
          "lng",
          "themes",
          "blurb",
          "source"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "title": { "type": "string", "minLength": 1 },
          "work": { "type": "string", "minLength": 1 },
          "composer": { "type": "string", "minLength": 1 },
          "year": { "type": "integer" },
          "city": { "type": "string", "minLength": 1 },
          "country": { "type": "string", "minLength": 1 },
          "lat": { "type": "number", "minimum": -90, "maximum": 90 },
          "lng": { "type": "number", "minimum": -180, "maximum": 180 },
          "themes": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
            "uniqueItems": true
          },
          "blurb": { "type": "string", "minLength": 1 },
          "source": { "$ref": "#/$defs/source" },
          "listening": {
            "type": "object",
            "additionalProperties": true,
            "required": ["target"],
            "properties": {
              "target": { "type": "string", "minLength": 1 },
              "query": { "type": "string" }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": true,
      "required": ["label", "url", "summary"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri" },
        "summary": { "type": "string", "minLength": 1 }
      }
    }
  }
}
